<%- include('./partial/head.ejs',) %>
<body>

    <main>
        <div>
            
            <h1><%= title %></h1>

        </div>
        <div>
            <form action="/auth/signup" method="POST">
                <label for="username">Username:</label>
                <input type="text" id="username" name="username" required minlength="2" maxlength="25">
                <label for="password">Password:</label>
                <input type="password" id="password" name="password" required minlength="8" maxlength="40">
                <input type="submit" value="submit"class="btn">
            </form>
            <p><%= err%></p>
            <a href="/">← Back</a>
        </div>
        <span>Already have an account? <a href="/user_login">Log in!</a></span>
    </main> 

</body>
</html>