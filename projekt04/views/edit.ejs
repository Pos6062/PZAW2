<%- include('./partial/head.ejs') %>
<body>
  <main>
    <h1><%= title %></h1>
    <a href="/">← Back</a>
    <% people.forEach(function(person){ %>
      <form action="/edit/values" method="POST">
        <div class="field">
          <label for="fname-<%= person.id %>">Change name</label>
          <input
            type="text"
            id="fname-<%= person.id %>"
            name="fname"
            value="<%= person.fname %>"
            required minlength="2" maxlength="30"
          />
        </div>

        <div class="field">
          <label for="lname-<%= person.id %>">Change surname</label>
          <input
            type="text"
            id="lname-<%= person.id %>"
            name="lname"
            value="<%= person.lname %>"
            required minlength="2" maxlength="30"
          />
        </div>

        <input type="hidden" name="id" value="<%= person.id %>" />
        <% if(person.author === user || attr.is_admin === true){ %>
        <div class="actions">
          <input type="submit" value="Update" name="update" class="btn success" style="background: var(--btn-success)" />
          <input type="submit" value="Delete" name="delete" class="btn danger" style="background: var(--btn-danger)"/>
        </div>
        <%}
          else{%>
          <p>no permission to edit this</p>
          <%}%>
      </form>
    <% }) %>
  </main>
</body>
</html>